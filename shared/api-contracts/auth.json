{
  "module": "auth",
  "description": "Authentication endpoints for customer login, registration, and session management",
  "baseUrl": "/auth",
  "endpoints": [
    {
      "method": "POST",
      "path": "/auth/customer/emailpass",
      "description": "Authenticate customer with email and password (login)",
      "auth": false,
      "request": {
        "body": {
          "email": "string (required)",
          "password": "string (required)"
        }
      },
      "response": {
        "token": "string (JWT)"
      },
      "errors": [
        { "status": 401, "code": "unauthorized", "message": "Invalid email or password" }
      ]
    },
    {
      "method": "POST",
      "path": "/auth/customer/emailpass/register",
      "description": "Register a new customer auth identity",
      "auth": false,
      "request": {
        "body": {
          "email": "string (required)",
          "password": "string (required)"
        }
      },
      "response": {
        "token": "string (JWT)"
      },
      "errors": [
        { "status": 422, "code": "duplicate", "message": "Email already registered" }
      ]
    },
    {
      "method": "POST",
      "path": "/auth/session",
      "description": "Create an authenticated session from a token",
      "auth": true,
      "request": {},
      "response": {}
    },
    {
      "method": "DELETE",
      "path": "/auth/session",
      "description": "Destroy the current session (logout)",
      "auth": true,
      "request": {},
      "response": {}
    },
    {
      "method": "POST",
      "path": "/auth/token/refresh",
      "description": "Refresh an expired auth token",
      "auth": true,
      "request": {},
      "response": {
        "token": "string (new JWT)"
      }
    }
  ]
}
