{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Molt Marketplace design tokens — Spacing & Layout",
  "spacing": {
    "xxs": 2,
    "xs": 4,
    "sm": 8,
    "md": 12,
    "base": 16,
    "lg": 24,
    "xl": 32,
    "xxl": 48,
    "xxxl": 64
  },
  "cornerRadius": {
    "none": 0,
    "small": 4,
    "medium": 8,
    "large": 12,
    "extraLarge": 16,
    "full": 999
  },
  "elevation": {
    "level0": 0,
    "level1": 1,
    "level2": 3,
    "level3": 6,
    "level4": 8,
    "level5": 12
  },
  "layout": {
    "screenPaddingHorizontal": 16,
    "screenPaddingVertical": 16,
    "cardPadding": 12,
    "listItemSpacing": 8,
    "sectionSpacing": 24,
    "productGridSpacing": 8,
    "productGridColumns": 2,
    "minTouchTarget": 48,
    "iconSize": {
      "small": 16,
      "medium": 24,
      "large": 32,
      "extraLarge": 48
    },
    "avatarSize": {
      "small": 32,
      "medium": 48,
      "large": 64,
      "extraLarge": 96
    },
    "productImageAspectRatio": "16:9",
    "bannerAspectRatio": "21:9"
  }
}
