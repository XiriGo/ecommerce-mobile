{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "component": "XGTextField",
  "category": "atom",
  "svgSource": "XiriGo_App_02.svg",

  "platform": {
    "ios": "ios/XiriGoEcommerce/Core/DesignSystem/Component/XGTextField.swift",
    "android": "android/app/src/main/java/com/xirigo/ecommerce/core/designsystem/component/XGTextField.kt"
  },

  "variants": {
    "default": {
      "background": "$foundations/colors.light.inputBackground",
      "borderColor": "$foundations/colors.light.inputBorder",
      "borderWidth": 1,
      "focusBorderWidth": 2,
      "focusBorderColor": "$foundations/colors.brand.primary",
      "errorBorderColor": "$foundations/colors.semantic.error",
      "textColor": "$foundations/colors.light.textPrimary",
      "placeholderColor": "$foundations/colors.light.inputPlaceholder",
      "labelColor": "$foundations/colors.light.inputLabel",
      "labelFont": "bodySmall (12pt Regular)",
      "textFont": "$foundations/typography.typeScale.bodyLarge",
      "height": 52,
      "cornerRadius": "$foundations/spacing.cornerRadius.medium",
      "horizontalPadding": "$foundations/spacing.spacing.md",
      "iconSize": "$foundations/spacing.layout.iconSize.medium"
    },
    "priceRange": {
      "background": "$foundations/colors.light.surfaceTertiary",
      "borderColor": "none",
      "textFont": "bodyMedium (14pt Medium)",
      "prefixText": "€",
      "svgReferenceWidth": 166,
      "_widthNote": "166 = SVG reference (2 price inputs side by side). In code: use weight(1f) / flexible() so both fields split available width equally.",
      "height": 37,
      "cornerRadius": "$foundations/spacing.cornerRadius.medium",
      "horizontalPadding": "$foundations/spacing.spacing.md"
    }
  },

  "subComponents": {
    "label": { "font": "bodySmall", "color": "dynamic (focus/error/default)" },
    "input": { "font": "bodyLarge" },
    "helperText": { "font": "bodySmall", "color": "onSurfaceVariant" },
    "errorText": { "font": "bodySmall", "color": "error" },
    "trailingIcon": { "password toggle": "eye/eye.slash" },
    "characterCount": { "font": "bodySmall", "color": "onSurfaceVariant" }
  }
}
