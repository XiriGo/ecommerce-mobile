{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "component": "XGSocialLoginButton",
  "category": "molecule",
  "svgSource": "XiriGo_App_02.svg",
  "status": "token-only (uses XGButton.social variant)",

  "variants": {
    "google": {
      "svgReferenceWidth": 153,
      "_widthNote": "153 = SVG reference (2 buttons side by side in 390px). In code: use weight(1f) / flexible() so both buttons split available width equally.",
      "height": 44,
      "cornerRadius": "$foundations/spacing.cornerRadius.medium",
      "background": "$foundations/colors.light.surface",
      "borderColor": "$foundations/colors.light.borderDefault",
      "borderWidth": 1,
      "textColor": "$foundations/colors.light.textPrimary",
      "font": "bodyMedium (14pt Medium)",
      "iconColors": "$foundations/colors.socialAuth.google*"
    },
    "apple": {
      "svgReferenceWidth": 153,
      "_widthNote": "153 = SVG reference (2 buttons side by side in 390px). In code: use weight(1f) / flexible() so both buttons split available width equally.",
      "height": 44,
      "cornerRadius": "$foundations/spacing.cornerRadius.medium",
      "background": "$foundations/colors.light.surface",
      "borderColor": "$foundations/colors.light.borderDefault",
      "borderWidth": 1,
      "textColor": "$foundations/colors.light.textPrimary",
      "font": "bodyMedium (14pt Medium)",
      "iconColor": "$foundations/colors.socialAuth.appleBlack"
    }
  }
}
