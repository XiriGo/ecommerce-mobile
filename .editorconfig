# =============================================================================
# EditorConfig — Xirigo E-Commerce (Root)
# =============================================================================
# Universal editor configuration for all IDEs and editors.
# Reference: https://editorconfig.org
# =============================================================================

root = true

# =============================================================================
# Default rules for all files
# =============================================================================
[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

# =============================================================================
# Kotlin files (Android)
# =============================================================================
[*.{kt,kts}]
indent_size = 4
max_line_length = 120

# =============================================================================
# Swift files (iOS)
# =============================================================================
[*.swift]
indent_size = 4
max_line_length = 120

# =============================================================================
# Java files
# =============================================================================
[*.java]
indent_size = 4
max_line_length = 120

# =============================================================================
# XML files (Android resources, layouts, manifests)
# =============================================================================
[*.xml]
indent_size = 4

# =============================================================================
# JSON files (config, design tokens, API contracts)
# =============================================================================
[*.json]
indent_size = 2

# =============================================================================
# YAML files (CI/CD, configs)
# =============================================================================
[*.{yml,yaml}]
indent_size = 2

# =============================================================================
# TOML files (Gradle version catalogs)
# =============================================================================
[*.toml]
indent_size = 4

# =============================================================================
# Properties files (Gradle, local config)
# =============================================================================
[*.properties]
indent_size = 4
charset = utf-8

# =============================================================================
# Shell scripts
# =============================================================================
[*.{sh,bash,zsh}]
indent_size = 2
end_of_line = lf

# =============================================================================
# Markdown files — preserve trailing whitespace (line breaks)
# =============================================================================
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# =============================================================================
# Makefile — must use tabs
# =============================================================================
[Makefile]
indent_style = tab
indent_size = 4

# =============================================================================
# Plist files (iOS configuration)
# =============================================================================
[*.plist]
indent_size = 4

# =============================================================================
# Xcode project files
# =============================================================================
[*.pbxproj]
indent_size = 4
indent_style = tab

# =============================================================================
# Storyboard / XIB files (legacy, if any)
# =============================================================================
[*.{storyboard,xib}]
indent_size = 4

# =============================================================================
# Gradle wrapper properties
# =============================================================================
[gradle/wrapper/gradle-wrapper.properties]
indent_size = 4

# =============================================================================
# GitHub Actions / CI config
# =============================================================================
[.github/**/*.{yml,yaml}]
indent_size = 2

# =============================================================================
# Docker files
# =============================================================================
[Dockerfile*]
indent_size = 4

# =============================================================================
# Ruby files (Fastlane, Gemfile, Podfile)
# =============================================================================
[*.{rb,Gemfile,Podfile}]
indent_size = 2

# =============================================================================
# TypeScript / JavaScript (if any tooling scripts)
# =============================================================================
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2
max_line_length = 100

# =============================================================================
# CSS / SCSS (if any web assets)
# =============================================================================
[*.{css,scss,less}]
indent_size = 2

# =============================================================================
# HTML files
# =============================================================================
[*.html]
indent_size = 2

# =============================================================================
# GraphQL files
# =============================================================================
[*.{graphql,gql}]
indent_size = 2

# =============================================================================
# Protocol Buffers
# =============================================================================
[*.proto]
indent_size = 2

# =============================================================================
# SQL files
# =============================================================================
[*.sql]
indent_size = 2
