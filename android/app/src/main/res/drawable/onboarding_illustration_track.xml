        android:fillColor="#FFFFFF"
        android:fillAlpha="0.15"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3" />

    <!-- Cabin window -->
    <path
        android:pathData="M130,110 L155,110 L162,125 L130,125 Z"
        android:fillColor="#94D63A"
        android:fillAlpha="0.3" />

    <!-- Left wheel -->
    <path
