# SwiftFormat Configuration — Molt Marketplace iOS

--indent 4
--indentcase false
--trimwhitespace always
--voidtype void
--maxwidth 120
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--closingparen balanced
--commas always
--semicolons never
--stripunusedargs closure-only
--self remove
--selfrequired
--importgrouping alpha
--header strip
--disable redundantReturn
--disable trailingCommas
--swiftversion 6.2

--exclude ios/Pods,ios/.build,ios/DerivedData,.build
