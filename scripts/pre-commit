#!/bin/bash
# pre-commit — Git pre-commit hook for the Xirigo E-Commerce project
#
# Auto-fixes and checks code quality on staged files:
# - ktlintFormat + ktlintCheck for staged .kt files (Android)
# - swiftlint --fix + swiftformat + swiftlint --strict for staged .swift files (iOS)
#
# Fixes are applied automatically and re-staged. Commit is aborted only if
# unfixable errors remain.

set -uo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

# Resolve the project root (this hook lives in scripts/ or .git/hooks/ via symlink)
PROJECT_ROOT="$(git rev-parse --show-toplevel)"

FAILED=0

# ---------------------------------------------------------------------------
# Kotlin — ktlintFormat (auto-fix) then ktlintCheck (verify)
# ---------------------------------------------------------------------------
STAGED_KT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.kt$' || true)

if [ -n "$STAGED_KT_FILES" ]; then
    echo -e "${YELLOW}[pre-commit]${NC} Auto-formatting staged Kotlin files with ktlint..."

    # Auto-fix
    (cd "$PROJECT_ROOT/android" && ./gradlew ktlintFormat --quiet 2>&1) || true

    # Re-stage any fixed files
    for file in $STAGED_KT_FILES; do
        FULL_PATH="$PROJECT_ROOT/$file"
        if [ -f "$FULL_PATH" ]; then
            git add "$FULL_PATH"
        fi
    done

    # Verify
    if (cd "$PROJECT_ROOT/android" && ./gradlew ktlintCheck --quiet 2>&1); then
        echo -e "${GREEN}[pre-commit] ktlint passed.${NC}"
    else
        echo -e "${RED}[pre-commit] ktlint failed. Some issues could not be auto-fixed.${NC}"
        FAILED=1
    fi
else
    echo -e "${GREEN}[pre-commit]${NC} No staged .kt files — skipping ktlint."
fi

# ---------------------------------------------------------------------------
# Swift — swiftformat + swiftlint --fix (auto-fix) then swiftlint (verify)
# ---------------------------------------------------------------------------
STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$' || true)

if [ -n "$STAGED_SWIFT_FILES" ]; then
    echo -e "${YELLOW}[pre-commit]${NC} Auto-formatting staged Swift files..."

    # Check if tools are installed
    HAS_SWIFTFORMAT=0
    HAS_SWIFTLINT=0
    command -v swiftformat &> /dev/null && HAS_SWIFTFORMAT=1
    command -v swiftlint &> /dev/null && HAS_SWIFTLINT=1

    if [ "$HAS_SWIFTFORMAT" -eq 0 ] && [ "$HAS_SWIFTLINT" -eq 0 ]; then
        echo -e "${YELLOW}[pre-commit] swiftlint and swiftformat not found — skipping Swift lint.${NC}"
        echo -e "${YELLOW}  Install: brew install swiftlint swiftformat${NC}"
    else
        # Auto-fix with swiftformat (handles formatting, attributes, line length, etc.)
        if [ "$HAS_SWIFTFORMAT" -eq 1 ]; then
            for file in $STAGED_SWIFT_FILES; do
                FULL_PATH="$PROJECT_ROOT/$file"
                if [ -f "$FULL_PATH" ]; then
                    swiftformat "$FULL_PATH" --config "$PROJECT_ROOT/ios/.swiftformat" --quiet 2>/dev/null || true
                fi
            done
            echo -e "${GREEN}[pre-commit] swiftformat auto-fix applied.${NC}"
        fi

        # Auto-fix with swiftlint (handles prefer_self_in_static_references, etc.)
        if [ "$HAS_SWIFTLINT" -eq 1 ]; then
            for file in $STAGED_SWIFT_FILES; do
                FULL_PATH="$PROJECT_ROOT/$file"
                if [ -f "$FULL_PATH" ]; then
                    (cd "$PROJECT_ROOT/ios" && swiftlint --fix --quiet "$FULL_PATH" 2>/dev/null) || true
                fi
            done
            echo -e "${GREEN}[pre-commit] swiftlint auto-fix applied.${NC}"
        fi

        # Re-stage fixed files
        for file in $STAGED_SWIFT_FILES; do
            FULL_PATH="$PROJECT_ROOT/$file"
            if [ -f "$FULL_PATH" ]; then
                git add "$FULL_PATH"
            fi
        done

        # Verify with swiftlint --strict
        if [ "$HAS_SWIFTLINT" -eq 1 ]; then
            SWIFT_LINT_FAILED=0

            for file in $STAGED_SWIFT_FILES; do
                FULL_PATH="$PROJECT_ROOT/$file"
                if [ -f "$FULL_PATH" ]; then
                    if ! (cd "$PROJECT_ROOT/ios" && swiftlint lint --strict --quiet "$FULL_PATH" 2>&1); then
                        SWIFT_LINT_FAILED=1
                    fi
                fi
            done

            if [ "$SWIFT_LINT_FAILED" -eq 0 ]; then
                echo -e "${GREEN}[pre-commit] swiftlint passed.${NC}"
            else
                echo -e "${RED}[pre-commit] swiftlint failed. Some issues could not be auto-fixed.${NC}"
                FAILED=1
            fi
        fi
    fi
else
    echo -e "${GREEN}[pre-commit]${NC} No staged .swift files — skipping swiftlint."
fi

# ---------------------------------------------------------------------------
# Final result
# ---------------------------------------------------------------------------
if [ "$FAILED" -ne 0 ]; then
    echo ""
    echo -e "${RED}[pre-commit] One or more checks failed. Commit aborted.${NC}"
    echo -e "${YELLOW}  Fix the remaining issues manually and try again.${NC}"
    exit 1
fi

echo -e "${GREEN}[pre-commit] All checks passed.${NC}"
exit 0
