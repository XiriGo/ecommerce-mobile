#!/bin/bash
# pre-commit — Git pre-commit hook for the Xirigo E-Commerce project
#
# Runs code quality checks on staged files:
# - ktlintCheck for staged .kt files (Android)
# - swiftlint for staged .swift files (iOS)
#
# Only checks staged files for fast feedback. Exits with 1 if any check fails.

set -uo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

# Resolve the project root (this hook lives in scripts/ or .git/hooks/ via symlink)
PROJECT_ROOT="$(git rev-parse --show-toplevel)"

FAILED=0

# ---------------------------------------------------------------------------
# Kotlin — ktlintCheck via Gradle
# ---------------------------------------------------------------------------
STAGED_KT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.kt$' || true)

if [ -n "$STAGED_KT_FILES" ]; then
    echo -e "${YELLOW}[pre-commit]${NC} Checking staged Kotlin files with ktlint..."

    if (cd "$PROJECT_ROOT/android" && ./gradlew ktlintCheck --quiet 2>&1); then
        echo -e "${GREEN}[pre-commit] ktlint passed.${NC}"
    else
        echo -e "${RED}[pre-commit] ktlint failed. Fix lint errors before committing.${NC}"
        FAILED=1
    fi
else
    echo -e "${GREEN}[pre-commit]${NC} No staged .kt files — skipping ktlint."
fi

# ---------------------------------------------------------------------------
# Swift — swiftlint on staged files only
# ---------------------------------------------------------------------------
STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$' || true)

if [ -n "$STAGED_SWIFT_FILES" ]; then
    echo -e "${YELLOW}[pre-commit]${NC} Checking staged Swift files with swiftlint..."

    # Check if swiftlint is installed
    if ! command -v swiftlint &> /dev/null; then
        echo -e "${YELLOW}[pre-commit] swiftlint not found — skipping Swift lint.${NC}"
        echo -e "${YELLOW}  Install: brew install swiftlint${NC}"
    else
        SWIFT_LINT_FAILED=0

        # Lint each staged Swift file individually for targeted feedback
        for file in $STAGED_SWIFT_FILES; do
            FULL_PATH="$PROJECT_ROOT/$file"
            if [ -f "$FULL_PATH" ]; then
                if ! swiftlint lint --strict --quiet "$FULL_PATH" 2>&1; then
                    SWIFT_LINT_FAILED=1
                fi
            fi
        done

        if [ "$SWIFT_LINT_FAILED" -eq 0 ]; then
            echo -e "${GREEN}[pre-commit] swiftlint passed.${NC}"
        else
            echo -e "${RED}[pre-commit] swiftlint failed. Fix lint errors before committing.${NC}"
            FAILED=1
        fi
    fi
else
    echo -e "${GREEN}[pre-commit]${NC} No staged .swift files — skipping swiftlint."
fi

# ---------------------------------------------------------------------------
# Final result
# ---------------------------------------------------------------------------
if [ "$FAILED" -ne 0 ]; then
    echo ""
    echo -e "${RED}[pre-commit] One or more checks failed. Commit aborted.${NC}"
    echo -e "${YELLOW}  Fix the issues above and try again.${NC}"
    exit 1
fi

echo -e "${GREEN}[pre-commit] All checks passed.${NC}"
exit 0
